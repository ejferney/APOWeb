# Server environment variables (copy to .env)

# MongoDB connection string. For production use MongoDB Atlas:
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/apo-web
MONGODB_URI=mongodb://localhost:27017/apo-web

# REQUIRED in production: a long random string used to sign login tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Port the API listens on (most hosts set this for you)
PORT=5000

# Comma-separated list of allowed frontend origins for CORS.
# Leave unset in dev. In production e.g. https://apo-aez.vercel.app
CLIENT_URL=
